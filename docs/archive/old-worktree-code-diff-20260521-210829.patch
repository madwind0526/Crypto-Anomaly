+// ── WS live restart plugin ────────────────────────────────────────────────────
+const wsLivePath  = path.join(process.cwd(), "scripts", "ws-live.mjs");
+const wsPidDir    = path.join(process.cwd(), "data", "local", "paper-trading-1m-daily");
+const wsPidFile   = path.join(wsPidDir, "ws-live.pid");
+
+const wsState = { running: false, startedAt: "", pid: null, error: "" };
+
+function readSavedPid() {
+  try { return parseInt(readFileSync(wsPidFile, "utf8").trim(), 10); } catch { return null; }
+}
+
+function savePid(pid) {
+  try { mkdirSync(wsPidDir, { recursive: true }); writeFileSync(wsPidFile, String(pid), "utf8"); } catch { /* ignore */ }
+}
+
+function deletePidFile() {
+  try { unlinkSync(wsPidFile); } catch { /* ignore */ }
+}
+
+function killWsLive() {
+  // Kill by saved PID first (covers Vite-restart scenario where in-memory ref is lost)
+  const savedPid = readSavedPid();
+  if (savedPid) {
+    try {
+      if (process.platform === "win32") {
+        execSync(`taskkill /F /T /PID ${savedPid}`, { stdio: "ignore" });
+      } else {
+        execSync(`kill -TERM -$(ps -o pgid= -p ${savedPid} | tr -d ' ') 2>/dev/null || kill ${savedPid} || true`, { stdio: "ignore" });
+      }
+    } catch { /* already dead */ }
+    deletePidFile();
+  }
+  wsState.running = false;
+  wsState.pid = null;
+}
+
+function startWsLive() {
+  killWsLive();
+
+  const child = spawn("node", [wsLivePath], {
+    cwd: process.cwd(),
+    shell: false,
+    stdio: "ignore",
+    detached: false,
+  });
+
+  savePid(child.pid);
+  wsState.running = true;
+  wsState.startedAt = new Date().toISOString();
+  wsState.pid = child.pid;
+  wsState.error = "";
+
+  child.on("error", (err) => { wsState.error = err.message; wsState.running = false; deletePidFile(); });
+  child.on("close", (code) => {
+    wsState.running = false;
+    wsState.error = code !== null && code !== 0 ? `exit code ${code}` : "";
+    deletePidFile();
+  });
+}
+
+// Restore state from PID file on Vite startup
+const restoredPid = readSavedPid();
+if (restoredPid) { wsState.running = true; wsState.pid = restoredPid; }
+
+function wsRestartPlugin() {
+  return {
+    name: "ws-restart-api",
+    configureServer(server) {
+      server.middlewares.use("/api/ws/status", (_req, res) => {
+        sendJson(res, wsState);
+      });
+      server.middlewares.use("/api/ws/restart", (req, res) => {
+        if (req.method !== "POST") { res.statusCode = 405; sendJson(res, { error: "Method not allowed" }); return; }
+        startWsLive();
+        sendJson(res, wsState);
+      });
+    },
+  };
+}
+
 export default defineConfig({
-  plugins: [strategyRefreshPlugin(), react()],
+  plugins: [strategyRefreshPlugin(), wsRestartPlugin(), react()],
+  server: { port: 5177, strictPort: true },
 });
