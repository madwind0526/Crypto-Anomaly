+// ─── Candle accumulation ──────────────────────────────────────────────────────
+/**
+ * Merge freshly-fetched candles into the accumulated rolling window.
+ * Deduplicates by timestamp, sorts ascending, trims to ACCUM_DAYS.
+ */
+function mergeAccumCandles(
+  accum: Record<string, Candle[]>,
+  fresh: Record<string, Candle[]>,
+  keepSince: number,
+): Record<string, Candle[]> {
+  const merged: Record<string, Candle[]> = {};
+  const allMarkets = new Set([...Object.keys(accum), ...Object.keys(fresh)]);
+  for (const market of allMarkets) {
+    const existing = accum[market] ?? [];
+    const incoming = fresh[market] ?? [];
+    const byTs = new Map<number, Candle>();
+    for (const c of existing) byTs.set(c.timestamp, c);
+    for (const c of incoming) byTs.set(c.timestamp, c); // fresh overwrites stale
+    merged[market] = [...byTs.values()]
+      .filter(c => c.timestamp >= keepSince)
+      .sort((a, b) => a.timestamp - b.timestamp);
+  }
+  return merged;
+}
 function kstTodayStartMs(): number {
   const kstNow = Date.now() + KST_OFFSET_MS;
   return kstNow - (kstNow % MS_DAY) - KST_OFFSET_MS;
